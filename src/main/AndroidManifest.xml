<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.istream">
    <uses-permission android:name="android.permission.INTERNET"/>
    <application
        android:allowBackup="true"
        android:label="iStream"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.Light.NoActionBar">

        <!-- ✅ LOGIN (LAUNCHER ACTIVITY) -->
        <activity
            android:name=".activities.LoginActivity"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

        </activity>

        <!-- Other activities -->
        <activity android:name=".activities.SignupActivity" android:exported="false"/>
        <activity android:name=".activities.HomeActivity" android:exported="false"/>
        <activity android:name=".activities.PlayerActivity" android:exported="false"/>
        <activity android:name=".activities.PlaylistActivity" android:exported="false"/>

    </application>

</manifest>